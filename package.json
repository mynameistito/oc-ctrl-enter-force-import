{
  "name": "@mynameistito/oc-ctrl-enter-force-import",
  "version": "0.1.1",
  "description": "OpenCode TUI plugin that interrupts the active run and submits the prompt with Ctrl+Enter.",
  "keywords": [
    "ctrl-enter",
    "force-submit",
    "opencode",
    "opencode-plugin",
    "tui"
  ],
  "homepage": "https://github.com/mynameistito/oc-ctrl-enter-force-import#readme",
  "bugs": {
    "url": "https://github.com/mynameistito/oc-ctrl-enter-force-import/issues"
  },
  "license": "MIT",
  "author": "mynameistito",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mynameistito/oc-ctrl-enter-force-import.git"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/tui.mjs",
  "module": "./dist/tui.mjs",
  "types": "./dist/tui.d.mts",
  "exports": {
    ".": {
      "types": "./dist/tui.d.mts",
      "import": "./dist/tui.mjs"
    },
    "./tui": {
      "types": "./dist/tui.d.mts",
      "import": "./dist/tui.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "check": "ultracite check",
    "changeset": "changeset",
    "changeset-add": "bun ./scripts/changeset-add.ts",
    "knip": "bunx knip@latest",
    "fix": "ultracite fix",
    "typecheck": "tsc --noEmit",
    "prepack": "bun run build"
  },
  "dependencies": {
    "@types/node": "^26.1.1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "@opencode-ai/plugin": "^1.18.4",
    "@opentui/core": "^0.4.5",
    "@opentui/keymap": "^0.4.5",
    "@opentui/solid": "^0.4.5",
    "@types/bun": "^1.3.14",
    "lefthook": "^2.1.10",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "tsdown": "^0.22.12",
    "typescript": "^7.0.2",
    "ultracite": "7.9.4"
  }
}
